# VIPL Email Agent v2 — Environment Variables
# Copy to .env and fill in values. NEVER commit .env itself.

# === Local Dev (safe — no external API calls) ===
# With these defaults, `python manage.py test_pipeline` and
# `python manage.py run_scheduler --once --dry-run` will NOT
# hit any external APIs. Safe for local development.
#
# Quick start:
#   cp .env.example .env
#   python manage.py migrate
#   python manage.py test_pipeline          # fake emails, no API calls
#   python manage.py test_pipeline --count 5 --with-ai  # opt in to Claude
#   python manage.py run_scheduler --once --dry-run      # simulated cycle

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=local-dev-key-not-for-production
ALLOWED_HOSTS=localhost,127.0.0.1

# App version (set by CI/CD)
APP_VERSION=dev

# Database (SQLite for local dev — no setup needed)
# DATABASE_URL=  # Leave unset to use SQLite (config/settings/dev.py default)

# === External Services (uncomment to enable) ===
# Leave commented for safe local dev. Uncomment individually to test
# specific integrations (e.g. --with-ai flag on test_pipeline).
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/service-account.json
# GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/...

# === Google OAuth SSO ===
# Create at: GCP Console > APIs & Services > Credentials > OAuth 2.0 Client
# Redirect URI: https://YOUR_DOMAIN/accounts/google/login/callback/
# Store credentials in GCP Secret Manager for safety.
# GOOGLE_OAUTH_CLIENT_ID=123456789-xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx

# Comma-separated emails auto-approved as admin on first Google SSO login.
# All other @vidarbhainfotech.com users require manual approval via /accounts/team/.
# SUPERADMIN_EMAILS=admin@yourdomain.com

# === Production (set on VM via /opt/vipl-email-agent/.env) ===
# DJANGO_SETTINGS_MODULE=config.settings.prod
# SECRET_KEY=generate-a-strong-random-key-here
# ALLOWED_HOSTS=triage.vidarbhainfotech.com,localhost
# DATABASE_URL=postgres://vipl_agent:PASSWORD@taiga-docker-taiga-db-1:5432/vipl_email_agent
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/app/secrets/service-account.json
# GOOGLE_CHAT_WEBHOOK_URL=your-chat-webhook-url
# MONITORED_INBOXES=info@vidarbhainfotech.com,sales@vidarbhainfotech.com
# ADMIN_EMAIL=admin@yourdomain.com
# EOD_RECIPIENTS=admin@yourdomain.com
# GOOGLE_SHEET_ID=your-google-sheet-id
