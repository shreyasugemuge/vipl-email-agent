# ============================================================
# VIPL Email Agent — Environment Variables (Local Dev)
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# Anthropic API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheet ID (from the spreadsheet URL, between /d/ and /edit)
GOOGLE_SHEET_ID=your-spreadsheet-id-here

# Comma-separated inbox addresses to monitor
MONITORED_INBOXES=info@vidarbhainfotech.com,sales@vidarbhainfotech.com

# Admin email (receives escalations, fallback EOD)
ADMIN_EMAIL=shreyas@vidarbhainfotech.com

# EOD report recipients (comma-separated)
EOD_RECIPIENTS=shreyas@vidarbhainfotech.com

# Google Chat webhook URL
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/xxx/messages?key=xxx&token=xxx

# (Optional) Override config file path
# CONFIG_PATH=config.yaml
